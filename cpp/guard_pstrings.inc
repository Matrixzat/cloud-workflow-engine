// guard_pstrings.inc — AES-256-CBC + XOR 0x5A protected string literals.
//
// TWO decryption tiers:
//   reveal()    — master key (shared), used for VCore markers / blocked-class names
//   reveal_ns() — per-string unique key derived via FNV-1a mixing; every string
//                 has a distinct key, so finding one decrypt call reveals nothing
//                 about any other string.
//
// In addition every key derivation uses MBA (Mixed Boolean Arithmetic):
//   XOR is expressed as (a|b)-(a&b) — identical result, unrecognisable to
//   Ghidra / IDA Pro's decompiler and CFF-based static analysis.
//
// The g_is_safe_ns() safe-namespace whitelist runs entirely inside a custom
// bytecode VM whose opcode stream is AES-encrypted (NS_BC / NS_BLOBS below).

// ════════════════════════════════════════════════════════════════════════════
// GSTR — General-purpose compile-time XOR string obfuscation
//
// Used by dex2c-generated code so that URL / sensitive string literals
// never appear in .rodata.  ApkProtector.java scans every generated .cpp
// file BEFORE NDK compilation and replaces matching string literals with
// GSTR_DECRYPT() calls; the plaintext is encrypted with a per-string
// random XOR key and stored as a static byte array.
//
// Usage in generated code (inserted automatically by ApkProtector):
//   static const uint8_t _gse_0[] = {0x8b,0xf2,...};  // encrypted bytes
//   env->NewStringUTF(GSTR_DECRYPT(_gse_0, 26, 0xE3)) // decrypts at first call
//
// The lambda + static flag ensures decryption happens ONCE per string,
// not on every call.  The buffer lives in .bss (zero-init), never .rodata.
// ════════════════════════════════════════════════════════════════════════════

static __attribute__((always_inline)) inline const char *gstr_xor_dec(
        const uint8_t *enc, int len, uint8_t key, char *out) {
    for (int i = 0; i < len; i++) out[i] = (char)(enc[i] ^ key);
    out[len] = '\0';
    return out;
}

// GSTR_DECRYPT(arr, plain_len, xor_key)
//   arr      — static const uint8_t[] of XOR-encrypted bytes
//   plain_len — byte length of the plaintext (NOT including NUL)
//   xor_key  — single-byte XOR key (0x20–0xFE range, chosen by encryptor)
#define GSTR_DECRYPT(arr, plen, key)                        \
    ([]() -> const char* {                                   \
        static char _b[(plen)+1];                            \
        static bool _ok = false;                             \
        if (!_ok) {                                          \
            gstr_xor_dec((arr), (plen), (uint8_t)(key), _b);\
            _ok = true;                                      \
        }                                                    \
        return _b;                                           \
    }())

// ════════════════════════════════════════════════════════════════════════════
// Master-key reveal — shared key, VCore markers and blocked-class names
// ════════════════════════════════════════════════════════════════════════════
#define PSTR_XOR_MASK 0x5Au

static __attribute__((noinline)) const char *reveal(const uint8_t *ct, int ct_len, char *out) {
    uint8_t key[32], iv[16];
    build_key256(key); build_iv(iv);
    int plen = aes256_cbc_dec(key, iv, ct, ct_len, (uint8_t *)out);
    memset(key, 0, 32); memset(iv, 0, 16);
    if (plen < 0) { out[0] = '\0'; return out; }
    for (int i = 0; i < plen; i++) out[i] = (char)((uint8_t)out[i] ^ PSTR_XOR_MASK);
    out[plen] = '\0';
    return out;
}

