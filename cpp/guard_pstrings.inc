// ════════════════════════════════════════════════════════════════════════════
// Per-string unique key derivation
// ════════════════════════════════════════════════════════════════════════════
// FNV-1a32 mixer: maps a string index to a 32-bit mixing value.
// Matches the Python keygen exactly — do not alter either without updating both.
static __attribute__((noinline)) uint32_t ns_pstr_mix(uint32_t idx) {
    uint32_t h = 0x811c9dc5u;
    uint8_t b0=(uint8_t)(idx&0xFF),     b1=(uint8_t)((idx>>8)&0xFF);
    uint8_t b2=(uint8_t)((idx)^0x5Au),  b3=(uint8_t)((idx)^0xA3u);
    h=((h^(uint32_t)b0)*0x01000193u);
    h=((h^(uint32_t)b1)*0x01000193u);
    h=((h^(uint32_t)b2)*0x01000193u);
    h=((h^(uint32_t)b3)*0x01000193u);
    return h;
}

// Derives a unique 32-byte AES key for string index idx.
// MBA: each byte mixed via (a|b)-(a&b) instead of plain XOR.
static __attribute__((noinline)) void build_str_key(uint32_t idx, uint8_t *key) {
    build_key256(key);
    uint32_t mix = ns_pstr_mix(idx);
    for (int i = 0; i < 32; i++) {
        uint8_t m = (uint8_t)((mix >> (8*(i&3))) & 0xFFu);
        uint32_t a=(uint32_t)key[i], b=(uint32_t)m;
        key[i] = (uint8_t)((a|b)-(a&b));   // MBA XOR
        mix = (mix<<7)|(mix>>25);            // rotate left 7
    }
}

// Derives a unique 16-byte AES IV for string index idx (offset +100 to the mix).
static __attribute__((noinline)) void build_str_iv(uint32_t idx, uint8_t *iv) {
    build_iv(iv);
    uint32_t mix = ns_pstr_mix(idx + 100u);
    for (int i = 0; i < 16; i++) {
        uint8_t m = (uint8_t)((mix >> (8*(i&3))) & 0xFFu);
        uint32_t a=(uint32_t)iv[i], b=(uint32_t)m;
        iv[i] = (uint8_t)((a|b)-(a&b));
        mix = (mix<<7)|(mix>>25);
    }
}

// Per-string AES-256-CBC decrypt. buf must be >= ct_len bytes.
static __attribute__((noinline)) const char *reveal_ns(uint32_t idx,
                                                        const uint8_t *ct, int ct_len,
                                                        char *buf) {
    uint8_t key[32], iv[16];
    build_str_key(idx, key);
    build_str_iv(idx, iv);
    int plen = aes256_cbc_dec(key, iv, ct, ct_len, (uint8_t *)buf);
    memset(key, 0, 32); memset(iv, 0, 16);
    if (plen < 0) { buf[0] = '\0'; return buf; }
    for (int i = 0; i < plen; i++) buf[i] = (char)((uint8_t)buf[i] ^ PSTR_XOR_MASK);
    buf[plen] = '\0';
    return buf;
}

