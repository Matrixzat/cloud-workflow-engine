<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Uganda Cinema Plus: munowatch CDN serves video over plain HTTP only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">b-cdn.net</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">aoneroom.com</domain>
        <domain includeSubdomains="true">movbox.cc</domain>
        <domain includeSubdomains="true">hakunaymatata.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
